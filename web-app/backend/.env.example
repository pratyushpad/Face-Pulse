# Path to the trained .h5 model file
MODEL_PATH=../../best_vgg_model.h5

# Comma-separated allowed origins. "*" is fine for local dev (credentials are
# never used). If you deploy this API, set it to the exact frontend origin,
# e.g. https://emotion-detec.netlify.app
CORS_ORIGIN=*

# Server port (Render sets this automatically)
PORT=8000
